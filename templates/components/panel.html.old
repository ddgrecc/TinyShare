<h2 style="font-size: 1.5rem; margin-bottom: 20px; border-bottom: 2px solid var(--border); padding-bottom: 10px;">
    🔍 Details: {{ share.name }} <span style="font-size: 0.9rem; color: var(--text-muted);">{{ share.path }}</span>
</h2>
{% if has_errors %}
<div style="background: #fdebd0; border-left: 4px solid #e74c3c; padding: 15px; margin-bottom: 20px;">
    <strong>⚠️ Achtung:</strong> Samba-Rechte und Linux-Host-Rechte stimmen nicht überein!
</div>
{% endif %}
<table>
    <thead><tr><th>Benutzer</th><th>Samba (SMB)</th><th>NFS</th><th style="border-left: 2px solid var(--border);">Real-Test (Linux)</th></tr></thead>
    <tbody>
        {% for row in matrix %}
        <tr class="{% if row.sys_error %}error-row{% endif %}">
            <td style="font-weight: bold;">{{ row.username }}</td>
            <td>
                {% if row.samba_acc == 'rw' %}<span style="color:#27ae60; font-weight:bold;">RW</span>
                {% elif row.samba_acc == 'ro' %}<span style="color:#f39c12; font-weight:bold;">RO</span>
                {% else %}<span style="color:#e74c3c;">Kein Zugriff</span>{% endif %}
            </td>
            <td>{% if row.nfs_acc == 'rw' %}<span style="color:#27ae60;">Schreiben (IP)</span>{% else %}<span style="color:#bdc3c7;">Inaktiv</span>{% endif %}</td>
            <td style="border-left: 2px solid var(--border);">
                {% if row.practical_w %} <span style="color:#27ae60;">✔ Read / ✔ Write</span>
                {% elif row.practical_r %} <span style="color:#f39c12;">✔ Read / ✕ Write</span>
                {% else %} <span style="color:#e74c3c;">✕ Kein Zugriff</span> {% endif %}
                {% if row.sys_error %}<br><span style="font-size: 0.8rem; color: #c0392b; font-weight: bold;">(Konflikt!)</span>{% endif %}
            </td>
        </tr>
        {% endfor %}
    </tbody>
</table>
